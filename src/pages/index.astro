---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featured = posts.find((p) => p.data.featured) ?? posts[0];
const rest = posts.filter((p) => p.id !== featured?.id).slice(0, 6);
---

<BaseLayout>
  <!-- Hero -->
  <section class="border-b border-slate-100">
    <div class="mx-auto max-w-5xl px-4 py-16 sm:py-20">
      <h1 class="max-w-2xl text-4xl font-extrabold leading-tight text-ink sm:text-5xl">
        AI 学习笔记<span class="text-brand-600">.</span>
      </h1>
      <p class="mt-5 max-w-2xl text-lg leading-relaxed text-muted">
        记录我在学习 AI 路上的思考与实践：提示词工程、大模型原理、RAG、
        以及各类 AI 工具的实测与使用经验。写给自己，也希望帮到你。
      </p>
      <div class="mt-8">
        <a
          href="/blog"
          class="rounded-xl bg-brand-600 px-6 py-3 text-sm font-semibold text-white hover:bg-brand-700"
        >
          浏览全部文章 →
        </a>
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-5xl px-4 py-14">
    {
      featured && (
        <a
          href={`/blog/${featured.id}`}
          class="group mb-12 grid overflow-hidden rounded-3xl border border-slate-100 md:grid-cols-2"
        >
          {featured.data.cover ? (
            <img
              src={featured.data.cover}
              alt={featured.data.title}
              class="aspect-[16/10] w-full object-cover md:aspect-auto md:h-full"
            />
          ) : (
            <div class="flex aspect-[16/10] items-center justify-center bg-gradient-to-br from-brand-500 to-brand-700 text-3xl font-bold text-white/90 md:aspect-auto">
              {featured.data.tags[0] ?? '精选'}
            </div>
          )}
          <div class="flex flex-col justify-center p-8">
            <span class="mb-2 text-xs font-semibold uppercase tracking-wide text-brand-600">
              置顶阅读
            </span>
            <h2 class="text-2xl font-bold leading-snug text-ink group-hover:text-brand-600">
              {featured.data.title}
            </h2>
            <p class="mt-3 line-clamp-3 text-muted">{featured.data.description}</p>
            <span class="mt-4 text-sm font-semibold text-brand-600">阅读全文 →</span>
          </div>
        </a>
      )
    }

    <div class="mb-6 flex items-end justify-between">
      <h2 class="text-2xl font-bold text-ink">最新文章</h2>
      <a href="/blog" class="text-sm font-medium text-brand-600 hover:underline">
        查看全部 →
      </a>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {rest.map((post) => <PostCard post={post} />)}
    </div>
  </div>
</BaseLayout>
