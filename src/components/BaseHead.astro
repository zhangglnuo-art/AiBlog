---
// 统一的 <head>：canonical、OG、Twitter、favicon 与 JSON-LD 结构化数据全在这里。
// 每个页面通过 props 传入自己的 title/description，其余走全站默认。
import {
  SITE_TITLE,
  SITE_DESCRIPTION,
  SITE_NAME,
  SITE_LOGO,
  SITE_URL,
  TWITTER_HANDLE,
  GOOGLE_SITE_VERIFICATION,
} from '../consts';

interface Props {
  title?: string;
  /** 完整标题覆盖（首页用，避免拼接品牌后缀过长） */
  fullTitle?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  /** 直接注入的 JSON-LD 对象（如 Article / BreadcrumbList） */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  fullTitle,
  description = SITE_DESCRIPTION,
  image = '/og-default.png',
  imageAlt,
  type = 'website',
  publishedTime,
  modifiedTime,
  jsonLd,
} = Astro.props;

const pageTitle = fullTitle ?? (title ? `${title} | ${SITE_TITLE}` : SITE_TITLE);
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const imageURL = new URL(image, Astro.site);
const ogImageAlt = imageAlt ?? title ?? SITE_TITLE;

// 全站品牌实体：让搜索引擎建立 Organization / WebSite 实体，是 sitelinks / 知识面板的基础。
const siteJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: SITE_TITLE,
    url: SITE_URL,
    inLanguage: 'zh-CN',
    description: SITE_DESCRIPTION,
    publisher: { '@id': `${SITE_URL}/#organization` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': `${SITE_URL}/#organization`,
    name: SITE_NAME,
    url: SITE_URL,
    logo: {
      '@type': 'ImageObject',
      url: new URL(SITE_LOGO, SITE_URL).toString(),
      width: 512,
      height: 512,
    },
  },
];

const pageJsonLd = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const allJsonLd = [...siteJsonLd, ...pageJsonLd];
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="theme-color" content="#05070f" />
{
  GOOGLE_SITE_VERIFICATION && (
    <meta name="google-site-verification" content={GOOGLE_SITE_VERIFICATION} />
  )
}

<!-- Favicon：SVG 优先，PNG 回退，iOS 桌面图标 -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

<link rel="sitemap" href="/sitemap-index.xml" />
<link
  rel="alternate"
  type="application/rss+xml"
  title={SITE_TITLE}
  href={new URL('rss.xml', Astro.site)}
/>

<title>{pageTitle}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
<meta name="robots" content="index, follow, max-image-preview:large" />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:site_name" content={SITE_TITLE} />
<meta property="og:title" content={title ?? SITE_TITLE} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={imageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={ogImageAlt} />
<meta property="og:locale" content="zh_CN" />
{publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
{modifiedTime && <meta property="article:modified_time" content={modifiedTime.toISOString()} />}

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
{TWITTER_HANDLE && <meta name="twitter:site" content={TWITTER_HANDLE} />}
{TWITTER_HANDLE && <meta name="twitter:creator" content={TWITTER_HANDLE} />}
<meta name="twitter:title" content={title ?? SITE_TITLE} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageURL} />
<meta name="twitter:image:alt" content={ogImageAlt} />

<script type="application/ld+json" set:html={JSON.stringify(allJsonLd)} />
