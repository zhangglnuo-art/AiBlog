---
import { SITE_TITLE, NAV_LINKS } from '../consts';
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="sticky top-0 z-40 border-b border-slate-100 bg-white/85 backdrop-blur">
  <nav class="mx-auto flex h-16 max-w-5xl items-center justify-between px-4">
    <a href="/" class="flex items-center gap-2 font-bold text-ink">
      <span class="grid h-8 w-8 place-items-center rounded-lg bg-brand-600 text-sm text-white">ib</span>
      <span class="text-lg">{SITE_TITLE}</span>
    </a>

    <div class="flex items-center gap-1">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            class:list={[
              'rounded-lg px-3 py-2 text-sm font-medium transition-colors',
              isActive(link.href)
                ? 'text-brand-700'
                : 'text-slate-600 hover:text-brand-600',
            ]}
          >
            {link.label}
          </a>
        ))
      }
      <a
        href="/rss.xml"
        title="RSS 订阅"
        class="ml-1 rounded-lg p-2 text-slate-400 transition-colors hover:text-brand-600"
        aria-label="RSS 订阅"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M6.18 15.64a2.18 2.18 0 1 1 0 4.36 2.18 2.18 0 0 1 0-4.36ZM4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44Zm0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"/>
        </svg>
      </a>
    </div>
  </nav>
</header>
